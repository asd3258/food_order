# Copy this file to ".env" (same folder as docker-compose.yml) and fill in
# whichever key(s) you have. Never commit the real .env file -- it's already
# in .gitignore.
#
# v0.9: AI 菜單解析 (上傳菜單照片,AI 自動解析品項) tries Gemini first, and
# falls back to OpenAI if Gemini isn't configured or fails. You only need
# ONE of these to be set for the feature to work; setting both just gives you
# the fallback safety net.

# Get a free key at https://aistudio.google.com/apikey (see README.md for
# the full walkthrough). Free tier: 1500 requests/day on Flash models --
# plenty for a 17-person team uploading the occasional menu photo.
GEMINI_API_KEY=

# Optional -- defaults to gemini-2.5-flash if not set.
# GEMINI_MODEL=gemini-2.5-flash

# Get a key at https://platform.openai.com/api-keys (requires billing set up
# -- OpenAI's free tier for new accounts is limited/time-boxed).
OPENAI_API_KEY=

# Optional -- defaults to gpt-4o-mini if not set.
# OPENAI_MODEL=gpt-4o-mini

# v0.10: Google Places API (New) -- powers "從 Google Map 讀取電話/地址/營業時間"
# on the Create/Edit restaurant screens. This is a DIFFERENT Google product
# from Gemini above -- separate Cloud project, and Google requires a billing
# account (credit card on file) before this key will work at all, even
# though normal team usage should stay inside the $200/month Maps Platform
# free credit. See README.md for the full setup walkthrough.
GOOGLE_MAPS_API_KEY=
